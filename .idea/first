    public static void main(String[] args) {

        BookingHistory history = new BookingHistory();
        BookingReportService reportService = new BookingReportService();

        // Simulating confirmed bookings
        history.addReservation(new Reservation("R101", "Asha", "Deluxe", 3000));
        history.addReservation(new Reservation("R102", "Rahul", "Suite", 5000));
        history.addReservation(new Reservation("R103", "Neha", "Standard", 2000));

        // Admin views history
        List<Reservation> allBookings = history.getAllReservations();

        reportService.showAllBookings(allBookings);
        reportService.generateSummary(allBookings);
    }
}

