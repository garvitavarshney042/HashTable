import java.util.HashMap;
import java.util.Map;

public class TrainConsistManagementApp {
    public static void main(String[] args) {
        // Create a HashMap to store bogie-capacity mapping
        HashMap<String, Integer> bogieCapacityMap = new HashMap<>();

        // Insert bogies with their capacities using put()
        bogieCapacityMap.put("Sleeper", 72);       // 72 seats
        bogieCapacityMap.put("AC Chair", 56);      // 56 seats
        bogieCapacityMap.put("First Class", 24);   // 24 seats
        bogieCapacityMap.put("Rectangular Goods", 10000); // 10,000 kg load
        bogieCapacityMap.put("Cylindrical Goods", 8000);  // 8,000 kg load

        // Display bogie-capacity details using entrySet()
        System.out.println("Train Consist Capacity Details:");
        for (Map.Entry<String, Integer> entry : bogieCapacityMap.entrySet()) {
            System.out.println("Bogie: " + entry.getKey() + " | Capacity: " + entry.getValue());
        }
    }
}
